# infra/apisix/.env — copy to .env and fill in. NEVER commit the real .env.
# These feed docker-compose.yml (local stack). On the real server, set the same
# values in your APISIX/gateway environment.

# Shared secret proving a forward-auth call came from APISIX. Must be IDENTICAL
# to the gateway's GATEWAY_FORWARD_AUTH_SECRET.  Generate: openssl rand -hex 32
GATEWAY_FORWARD_AUTH_SECRET=

# --- passed through to the gateway container in the local stack ---
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
API_KEY_PEPPER=                      # same value as the portal;  openssl rand -hex 32

# The Mustang upstream host is fixed in apisix.tpl.yaml:
#   einvoiceservice.officefreund.de:443  (https)
# Change it there if the target moves.
