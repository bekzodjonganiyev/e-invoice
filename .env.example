# =============================================================================
# ROOT .env.example — placeholders only. Copy per-app values into the files
# listed below. NEVER commit real secrets (.env / .env.local are git-ignored).
# =============================================================================
#
# apps/portal/.env.local
#   NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx   # PUBLIC — reaches browser (RLS on)
#   SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx            # SERVER ONLY — never the browser
#   API_KEY_PEPPER=<openssl rand -hex 32>              # SERVER ONLY — identical to Gateway
#
# apps/gateway/.env
#   SUPABASE_URL=https://<ref>.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx            # bypasses RLS
#   REDIS_URL=redis://localhost:6379
#   API_KEY_PEPPER=<same value as portal>
#   GATEWAY_FORWARD_AUTH_SECRET=<openssl rand -hex 32> # shared with APISIX; gates /auth
#   PORT=4000
#
# infra/apisix/.env
#   MUSTANG_BASE_URL=https://einvoiceservice.officefreund.de
#   GATEWAY_AUTH_URL=http://gateway:4000/auth
#   GATEWAY_FORWARD_AUTH_SECRET=<same value as gateway>
#
# Optional (migration tooling only, not runtime):
#   SUPABASE_DB_URL=postgresql://postgres:[password]@db.<ref>.supabase.co:5432/postgres
#
# Google OAuth credentials are NOT in any of these files — the Google Client ID
# + Secret are entered in the Supabase Dashboard (Auth -> Providers -> Google).
