# =============================================================================
# ROOT .env.example — placeholders only. NEVER commit real secrets
# (.env / .env.* are git-ignored and excluded from the Docker build context).
#
# This file has two audiences:
#   1. VPS DEPLOY  — `docker compose` reads a single root .env. That is the
#                    block directly below; copy this file to .env and fill it.
#   2. LOCAL DEV   — running the apps outside Docker still uses the per-app
#                    files described at the bottom.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. VPS DEPLOY — root .env, consumed by docker-compose.yml
# -----------------------------------------------------------------------------

# --- Supabase ---
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx          # bypasses RLS — server only

# Public values: the browser sees these (RLS protects the anon key). Next
# INLINES them at build time, so changing either one needs a rebuild:
#   docker compose up -d --build portal
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- Shared secrets ---
# Used by BOTH portal and gateway and they must match byte for byte: the portal
# hashes a new key with this pepper, the gateway rehashes on every request to
# compare. A mismatch means every call 403s with no obvious cause.
#   generate: openssl rand -hex 32
API_KEY_PEPPER=<openssl rand -hex 32>

# Shared with APISIX. APISIX injects it as X-Gateway-Secret; the gateway rejects
# any /auth call without it. Must equal the value in the APISIX route config.
#   generate: openssl rand -hex 32
GATEWAY_FORWARD_AUTH_SECRET=<openssl rand -hex 32>

# --- Redis ---
# Nothing to set. This stack runs its own Redis container, reached internally as
# redis://redis:6379. It is separate from any Redis already on the VPS host and
# cannot collide with it, whatever port the host one uses.

# --- Docker networking ---
# Name of the Docker network APISIX's own stack already created, so the gateway
# can join it and APISIX can reach it as http://gateway:4000. The value below is
# the real one on the current VPS (srv849955), confirmed via `docker network ls`
# — it is the compose project name `docker-apisix` + the network name `apisix`.
# Re-check it if APISIX is ever redeployed from a differently-named directory.
APISIX_NETWORK=docker-apisix_apisix

# Host port the portal is published on, bound to 127.0.0.1. Point your reverse
# proxy (TLS for the portal's domain) at this.
PORTAL_PORT=3000

# -----------------------------------------------------------------------------
# 2. LOCAL DEV — per-app env files (not used by docker compose)
# -----------------------------------------------------------------------------
#
# apps/portal/.env.local
#   NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx   # PUBLIC — reaches browser (RLS on)
#   SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx            # SERVER ONLY — never the browser
#   API_KEY_PEPPER=<openssl rand -hex 32>              # SERVER ONLY — identical to Gateway
#
# apps/gateway/.env
#   SUPABASE_URL=https://<ref>.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx            # bypasses RLS
#   REDIS_URL=redis://localhost:6379
#   API_KEY_PEPPER=<same value as portal>
#   GATEWAY_FORWARD_AUTH_SECRET=<openssl rand -hex 32> # shared with APISIX; gates /auth
#   PORT=4000
#
# NOTE: the gateway does NOT auto-load its .env. Run it as:
#   set -a; . apps/gateway/.env; set +a; node apps/gateway/dist/main.js
#
# Optional (migration tooling only, not runtime):
#   SUPABASE_DB_URL=postgresql://postgres:[password]@db.<ref>.supabase.co:5432/postgres
#
# Google OAuth credentials are NOT in any of these files — the Google Client ID
# + Secret are entered in the Supabase Dashboard (Auth -> Providers -> Google).
